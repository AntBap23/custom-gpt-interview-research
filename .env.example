OPENAI_API_KEY=your-openai-api-key

# Backend hosting
PORT=8000
CORS_ORIGINS=http://127.0.0.1:8000,http://localhost:8000,https://qualitative-ai-studio.onrender.com
STORAGE_BACKEND=supabase
LOCAL_STORAGE_ROOT=backend_data

# Supabase-backed storage/auth
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Local cookie settings
AUTH_ACCESS_COOKIE_NAME=qa_access_token
AUTH_REFRESH_COOKIE_NAME=qa_refresh_token
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAMESITE=lax
